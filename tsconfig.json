{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@pureq/pureq": ["packages/pureq/src/index.ts"],
      "@pureq/auth": ["packages/auth/src/index.ts"],
      "@pureq/validation": ["packages/validation/src/index.ts"],
      "@pureq/db": ["packages/db/src/index.ts"]
    }
  },
  "include": [],
  "references": [
    { "path": "./packages/pureq" },
    { "path": "./packages/auth" },
    { "path": "./packages/validation" },
    { "path": "./packages/db" }
  ]
}
