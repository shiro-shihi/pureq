{
  "name": "@pureq/validation",
  "version": "1.0.0",
  "description": "Policy-ready validation primitives for pureq",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --build tsconfig.json",
    "check:language-policy": "node ./scripts/check-language-policy.mjs docs src",
    "check:no-throw": "node ./scripts/check-no-throw.mjs src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests",
    "test:ci": "pnpm run check:language-policy && pnpm run check:no-throw && pnpm run test:unit && pnpm run typecheck"
  },
  "keywords": [
    "validation",
    "schema",
    "typescript",
    "result"
  ],
  "author": "shiro-shihi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiro-shihi/pureq.git",
    "directory": "packages/validation"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}