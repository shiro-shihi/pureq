{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "paths": {
      "@pureq/db": ["../db/src/index.ts"]
    }
  },
  "references": [
    { "path": "../db" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
