{
  "name": "pureq-monorepo",
  "version": "0.0.0",
  "description": "pureq - A policy-first HTTP transport layer for TypeScript",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --recursive run build",
    "build:pureq": "pnpm --filter @pureq/pureq build",
    "build:auth": "pnpm --filter @pureq/auth build",
    "typecheck": "pnpm --recursive run typecheck",
    "test": "pnpm --recursive run test",
    "test:unit": "pnpm --recursive run test:unit",
    "test:integration": "pnpm --recursive run test:integration",
    "test:contract": "pnpm --recursive run test:contract",
    "test:stress": "pnpm --recursive run test:stress",
    "test:ci": "pnpm --recursive run test:ci",
    "test:ci:full": "pnpm --recursive run test:ci:full",
    "test:browser": "pnpm --filter @pureq/pureq run test:browser",
    "test:edge": "pnpm --filter @pureq/pureq run test:edge",
    "benchmark": "pnpm --filter @pureq/pureq run benchmark",
    "lint": "pnpm --recursive run lint",
    "clean": "pnpm --recursive run clean && pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "pnpm": "^10.33.0"
  }
}
